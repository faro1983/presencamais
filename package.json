{
  "name": "presenca-mais",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:functions": "firebase deploy --only functions --project $FIREBASE_PROJECT_ID --token $FIREBASE_TOKEN",
    "eas:build": "eas build --platform android --profile production-apk --non-interactive",
    "eas:build-aab": "eas build --platform android --profile production-aab --non-interactive",
    "ci:deploy": "npm run build:functions && npm run eas:build && npm run eas:build-aab"
  },
  "dependencies": {
    "expo": "~48.0.0",
    "react": "18.2.0",
    "react-native": "0.71.0",
    "firebase": "^9.22.0",
    "expo-camera": "~13.2.0",
    "axios": "^1.4.0",
    "@react-navigation/native": "^6.1.6",
    "@react-navigation/native-stack": "^6.9.12",
    "react-native-screens": "~3.20.0",
    "react-native-safe-area-context": "4.5.0",
    "react-native-gesture-handler": "~2.9.0",
    "react-native-paper": "^5.0.0",
    "react-native-vector-icons": "^9.2.0"
  },
  "devDependencies": {
    "typescript": "^5.4.2",
    "@types/react": "^18.2.21",
    "@types/react-native": "^0.71.9"
  }
}
