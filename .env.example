# Exemplo de variáveis de ambiente para desenvolvimento local
# NÃO comite este arquivo com valores reais; use apenas como modelo.

# Variáveis públicas do Firebase (cliente) - prefixo EXPO_PUBLIC_ para Expo
EXPO_PUBLIC_FIREBASE_API_KEY=SUAS_FIREBASE_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=seuprojeto.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=seuprojeto
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=seuprojeto.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=SEU_MESSAGING_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=1:xxxx:web:abcdef

# URL do backend (Cloud Functions) - opcional local
BACKEND_URL=http://localhost:5001/seuprojeto/us-central1

# NOTA: chaves sensíveis (AZURE_FACE_KEY, AZURE_FACE_ENDPOINT, service account do Firebase)
# DEVEM ficar apenas no backend (Cloud Functions) ou em secrets do provedor de CI/EAS.
